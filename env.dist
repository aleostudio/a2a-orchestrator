# App config (127.0.0.1 for localhost, 0.0.0.0 for whole network)
APP_NAME="A2A orchestrator"
APP_VERSION="0.1.0"
APP_HOST=0.0.0.0
APP_PORT=9301

# Logging
DEBUG=False

# A2A registry
REGISTRY_URL=http://localhost:9300
REGISTRY_TIMEOUT_S=4.0
REGISTRY_RETRIES=2
SKILLS_CACHE_TTL_S=60.0
SKILLS_CACHE_REFRESH_INTERVAL_S=30.0

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_S=8.0

# A2A
AGENT_TIMEOUT_S=12.0
AGENT_RETRIES=1
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RECOVERY_SECONDS=20
ROUTE_CONFIDENCE_THRESHOLD=0.6
